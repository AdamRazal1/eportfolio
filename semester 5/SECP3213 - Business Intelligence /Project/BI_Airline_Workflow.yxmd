                <FormulaField expression="[weather_delay] + [late_aircraft_delay]" field="total_delay_min" size="8" type="Double" />
                <FormulaField expression="IF [weather_delay] + [late_aircraft_delay] &lt;= 15 THEN 1 ELSE 0 ENDIF" field="on_time_flag" size="2" type="Int16" />
                <FormulaField expression="IF [weather_delay] + [late_aircraft_delay] = 0 THEN &quot;On Time&quot;&#xA;ELSEIF [weather_delay] + [late_aircraft_delay] &lt;= 15 THEN &quot;Minor&quot;&#xA;ELSEIF [weather_delay] + [late_aircraft_delay] &lt;= 45 THEN &quot;Moderate&quot;&#xA;ELSEIF [weather_delay] + [late_aircraft_delay] &lt;= 120 THEN &quot;Severe&quot;&#xA;ELSE &quot;Extreme&quot; ENDIF" field="delay_severity" size="20" type="V_String" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>Flight features: total_delay, on-time, severity</DefaultAnnotationText>
              <Left value="False" />
            </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
