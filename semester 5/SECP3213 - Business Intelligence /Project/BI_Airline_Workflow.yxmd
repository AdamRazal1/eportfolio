                <FormulaField expression="IF [Departure Delay in Minutes] = 0 THEN &quot;On Time&quot;&#xA;ELSEIF [Departure Delay in Minutes] &lt;= 15 THEN &quot;Minor&quot;&#xA;ELSEIF [Departure Delay in Minutes] &lt;= 45 THEN &quot;Moderate&quot;&#xA;ELSEIF [Departure Delay in Minutes] &lt;= 120 THEN &quot;Severe&quot;&#xA;ELSE &quot;Extreme&quot; ENDIF" field="delay_severity" size="20" type="V_String" />
              </FormulaFields>
