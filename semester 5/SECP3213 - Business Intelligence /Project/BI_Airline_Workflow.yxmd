    <Node ToolID="105">
      <GuiSettings Plugin="AlteryxGuiToolkit.ToolContainer.ToolContainer">
        <Position x="1181" y="124" width="412" height="180" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Caption>5. Analytical Techniques</Caption>
          <Style TextColor="#3a2a5a" FillColor="#e1d4f5" BorderColor="#5a3a9a" Transparency="25" Margin="25" />
          <Disabled value="False" />
          <Folded value="False" />
        </Configuration>
        <Annotation DisplayMode="0">
          <Name />
          <DefaultAnnotationText>Apply trend, predictive and segmentation logic on integrated dataset</DefaultAnnotationText>
          <Left value="False" />
        </Annotation>
      </Properties>
      <ChildNodes>
        <Node ToolID="17">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="1206" y="173" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="IF [month] &lt;= 3 THEN &quot;Q1&quot;&#xA;ELSEIF [month] &lt;= 6 THEN &quot;Q2&quot;&#xA;ELSEIF [month] &lt;= 9 THEN &quot;Q3&quot;&#xA;ELSE &quot;Q4&quot; ENDIF" field="quarter" size="2" type="V_String" />
                <FormulaField expression="IF [month] = 12 OR [month] = 1 OR [month] = 2 THEN &quot;Winter&quot;&#xA;ELSEIF [month] = 3 OR [month] = 4 OR [month] = 5 THEN &quot;Spring&quot;&#xA;ELSEIF [month] = 6 OR [month] = 7 OR [month] = 8 THEN &quot;Summer&quot;&#xA;ELSE &quot;Fall&quot; ENDIF" field="season" size="10" type="V_String" />
                <FormulaField expression="IF [month] = 6 OR [month] = 7 OR [month] = 8 OR [month] = 12 THEN 1 ELSE 0 ENDIF" field="is_peak_season" size="2" type="Int16" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>Trend Analysis: quarter, season, peak flag</DefaultAnnotationText>
              <Left value="False" />
            </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
        <Node ToolID="18">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="1338" y="174" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="IF [arr_flights] &gt; 0 THEN [arr_del15] / [arr_flights] ELSE 0 ENDIF" field="delay_propensity" size="8" type="Double" />
                <FormulaField expression="IF [delay_propensity] &lt; 0.10 THEN &quot;Low Risk&quot;&#xA;ELSEIF [delay_propensity] &lt; 0.20 THEN &quot;Medium Risk&quot;&#xA;ELSEIF [delay_propensity] &lt; 0.35 THEN &quot;High Risk&quot;&#xA;ELSE &quot;Critical Risk&quot; ENDIF" field="risk_tier" size="20" type="V_String" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>Predictive Logic: delay propensity &amp; risk tier</DefaultAnnotationText>
              <Left value="False" />
            </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
        <Node ToolID="19">
          <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
            <Position x="1470" y="174" />
          </GuiSettings>
          <Properties>
            <Configuration>
              <FormulaFields>
                <FormulaField expression="IF [carrier_ct] &gt;= [weather_ct] AND [carrier_ct] &gt;= [nas_ct] AND [carrier_ct] &gt;= [security_ct] AND [carrier_ct] &gt;= [late_aircraft_ct] THEN &quot;Carrier&quot;&#xA;ELSEIF [late_aircraft_ct] &gt;= [weather_ct] AND [late_aircraft_ct] &gt;= [nas_ct] AND [late_aircraft_ct] &gt;= [security_ct] THEN &quot;Late Aircraft&quot;&#xA;ELSEIF [nas_ct] &gt;= [weather_ct] AND [nas_ct] &gt;= [security_ct] THEN &quot;NAS&quot;&#xA;ELSEIF [weather_ct] &gt;= [security_ct] THEN &quot;Weather&quot;&#xA;ELSE &quot;Security&quot; ENDIF" field="dominant_delay_cause" size="20" type="V_String" />
                <FormulaField expression="IF [dominant_delay_cause] = &quot;Carrier&quot; OR [dominant_delay_cause] = &quot;Late Aircraft&quot; THEN &quot;Controllable&quot; ELSE &quot;Uncontrollable&quot; ENDIF" field="controllability" size="20" type="V_String" />
              </FormulaFields>
            </Configuration>
            <Annotation DisplayMode="0">
              <Name />
              <DefaultAnnotationText>Segmentation: dominant cause &amp; controllability</DefaultAnnotationText>
              <Left value="False" />
            </Annotation>
          </Properties>
          <EngineSettings EngineDll="AlteryxBasePluginsEngine.dll" EngineDllEntryPoint="AlteryxFormula" />
        </Node>
      </ChildNodes>
    </Node>
